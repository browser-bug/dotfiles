Xft.dpi:    96
Xft.antialias:  1
Xft.hinting:    1
Xft.hintstyle:  hintmedium

URxvt.iso14755: false
URxvt.iso14755_52: false

!This controls jumps to previous/next words but conflicts with tabbed plugin
URxvt.keysym.Control-Right: \033[1;5C
URxvt.keysym.Control-Left: \033[1;5D

URxvt.termName: rxvt
URxvt.depth: 32
URxvt.transparent: false
URxvt.font: xft:Ubuntu Mono derivative Powerline:size=14
!URxvt.letterSpacing: -0.5
URxvt.scrollBar: false
!URxvt.iconFile: .rexim/icons/terminal-icon.png

URxvt*depth: 32

! gruvbox theme
URxvt*background:                     #282828
URxvt*foreground:                     #d5c4a1
URxvt*cursorColor:                    #d5c4a1

! URxvt*colorBD:                        color
! URxvt*colorIT:                        color
! URxvt*colorUL:                        color
! URxvt*colorRV:                        color
! URxvt*underlineColor:                 color
URxvt*scrollColor:                    #d5c4a1
! URxvt*troughColor:                    color
URxvt*highlightColor:                 #7c6f54
URxvt*highlightTextColor:             #bdae93
! URxvt*cursorColor2:                   color
! URxvt*pointerColor:                   color
! URxvt*pointerColor2:                  color
! URxvt*borderColor:                    color
! URxvt*tab-bg:                         colour
! URxvt*tab-fg:                         colour
! URxvt*tabbar-bg:                      colour
! URxvt*tabbar-fg:                      colour

URxvt*color0:                         #282828
URxvt*color1:                         #cc241d
Uxvt*color2:                         #98971a
URxvt*color3:                         #d79921
URxvt*color4:                         #458588
URxvt*color5:                         #b16286
URxvt*color6:                         #689d6a
URxvt*color7:                         #d5c4a1
URxvt*color8:                         #ebdbb2
URxvt*color9:                         #cc241d
URxvt*color10:                        #98971a
URxvt*color11:                        #d79921
URxvt*color12:                        #458588
URxvt*color13:                        #b16286
URxvt*color14:                        #689d6a
URxvt*color15:                        #fbf1c7

! 256 color space
URxvt*color16:                        #d65d0e
URxvt*color17:                        #a89984
URxvt*color18:                        #504945
URxvt*color19:                        #7c6f54
URxvt*color20:                        #bdae93
URxvt*color21:                        #ebdbb2R

URxvt.perl-ext-common:  default,resize-font,fullscreen,matcher

!matcher
URxvt.url-launcher: /usr/bin/xdg-open
URxvt.matcher.button: 1

!resize-font
URxvt.keysym.C-minus:  resize-font:smaller
URxvt.keysym.C-plus:  resize-font:bigger
URxvt.keysym.C-0:      resize-font:reset
URxvt.resize-font.step: 1

!clipboard
URxvt.keysym.Control-Shift-V: eval:paste_clipboard
URxvt.keysym.Control-Shift-C: eval:selection_to_clipboard

!tabbed
URxvt.tabbed.tabbar-fg: 4
URxvt.tabbed.tabbar-bg: 0
URxvt.tabbed.tab-fg: 15
URxvt.tabbed.tab-bg: 0

!carriage-return for zsh-autosuggestion \033 = ^[
URxvt.keysym.C-Return:     \033[[CE


